---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About | ${SITE_TITLE}`} description="A bit about Emma." />
		<style>
			main {
				max-width: 65ch;
				margin-inline: auto;
				padding: 1rem;
			}
			.portrait {
				float: right;
				width: 180px;
				border-radius: 8px;
				margin: 0.4rem 0 1rem 1.5rem;
			}
			.bio p {
				line-height: 1.7;
				color: rgb(var(--gray-dark));
			}
			.socials {
				display: flex;
				gap: 1.25rem;
				margin-top: 2.5rem;
				flex-wrap: wrap;
			}
			.socials a {
				text-decoration: none;
			}
			.socials a:hover {
				text-decoration: underline;
			}
			@media (max-width: 480px) {
				.portrait {
					float: none;
					display: block;
					margin: 0 0 1rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="bio">
				<img class="portrait" src="/emma.jpg" alt="Emma" />
				<p>
					I'm Emma. I like problems, and the ones people tend to bring me
					are usually about understanding what's really behind a decision or a
					behaviour that's confusing them. I've come to believe you can't do
					that well without building a true picture of how the world actually
					works, which is most of what I spend my time thinking about,
					especially the parts that touch the developer community and open
					source, which I think is about the most important thing ever.
				</p>
			</div>

			<div class="socials">
				<a href="https://x.com/emmaviolet">X</a>
				<a href="https://github.com/emmaviolet">GitHub</a>
				<a href="https://www.linkedin.com/in/emma-gabriel/">LinkedIn</a>
			</div>
		</main>
		<Footer />
	</body>
</html>
