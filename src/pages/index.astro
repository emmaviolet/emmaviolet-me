---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				max-width: 65ch;
				margin-inline: auto;
				padding: 1rem;
			}
			.intro {
				margin-block: 2rem 3rem;
			}
			.intro p {
				color: rgb(var(--gray-dark));
				line-height: 1.6;
				margin: 0;
			}
			ul.posts {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			ul.posts li {
				margin-block: 1.6rem;
			}
			ul.posts a {
				text-decoration: none;
			}
			ul.posts a:hover h2 {
				text-decoration: underline;
			}
			ul.posts h2 {
				margin: 0 0 0.2rem;
				font-size: 1.4rem;
			}
			.date {
				color: rgb(var(--gray));
				font-size: 0.9rem;
			}
			p.desc {
				margin: 0.3rem 0 0;
				color: rgb(var(--gray-dark));
				line-height: 1.5;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="intro">
				<p>
					I'm Emma. I like problems, and the ones people tend to bring me are usually about understanding what's really behind a decision or a behaviour that's confusing them. I've come to believe you can't do that well without building a true picture of how the world actually works, which is most of what I spend my time thinking about, especially the parts that touch the developer community and open source, which I think is about the most important thing ever.
				</p>
			</section>
			<ul class="posts">
				{
					posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<h2>{post.data.title}</h2>
							</a>
							<span class="date">
								<FormattedDate date={post.data.pubDate} />
							</span>
							<p class="desc">{post.data.description}</p>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
